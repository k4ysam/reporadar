# --- discovery ---
GH_TOKEN=                              # GitHub PAT (no scopes needed for public repos)

# --- LLM provider (pick ONE) ---
LLM_PROVIDER=openai                    # claude | gemini | openai
ANTHROPIC_API_KEY=                     # required if LLM_PROVIDER=claude
GEMINI_API_KEY=                        # required if LLM_PROVIDER=gemini
OPENAI_API_KEY=                        # required if LLM_PROVIDER=openai
CLAUDE_MODEL=claude-sonnet-4-6
GEMINI_MODEL=gemini-2.0-flash
OPENAI_MODEL=gpt-5.4-mini
MAX_EVALUATIONS_PER_RUN=5
LLM_DAILY_LIMIT=20                     # daily cap for the selected LLM provider

# --- scanner thresholds ---
VELOCITY_WINDOW_HOURS=72
REPO_MAX_AGE_DAYS=365
STAR_GROWTH_MIN_PCT=50
STAR_BASE_MIN=10
MAX_CANDIDATES_PER_RUN=15
DEVPOST_MAX_PROJECTS_PER_RUN=25

# --- output paths ---
DB_PATH=reporadar.db
OUTPUT_DIR=output

# --- image hosting (S3 / R2 / B2 — anything boto3-compatible) ---
IMAGE_HOST_ENDPOINT=                   # e.g. https://<id>.r2.cloudflarestorage.com (R2). Leave blank for AWS S3.
IMAGE_HOST_BUCKET=                     # e.g. reporadar-cards
IMAGE_HOST_REGION=auto                 # 'auto' for R2; 'us-east-1' etc for AWS
IMAGE_HOST_PUBLIC_BASE_URL=            # e.g. https://cards.example.com  — must be HTTPS
IMAGE_HOST_ACCESS_KEY=
IMAGE_HOST_SECRET_KEY=

# --- instagram graph api ---
IG_ACCESS_TOKEN=                       # long-lived Page access token (60-day expiry)
IG_BUSINESS_ACCOUNT_ID=                # IG Business account ID linked to FB Page
IG_APP_ID=                             # Meta app id (for token refresh)
IG_APP_SECRET=                         # Meta app secret (for token refresh)
IG_DRY_RUN=0                           # 1 = render + upload but skip publishing

# --- scheduling ---
SCHEDULE_HOUR=6                        # local hour to fire pipeline daily
SCHEDULE_JITTER_MINUTES=15             # ±15 min per PRD anti-pattern detection
TIMEZONE=UTC                           # IANA TZ name (e.g. America/New_York)
