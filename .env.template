# --- discovery ---
GH_TOKEN=                              # GitHub PAT (no scopes needed for public repos)

# --- LLM provider (pick ONE) ---
LLM_PROVIDER=openai                    # claude | gemini | openai
ANTHROPIC_API_KEY=                     # required if LLM_PROVIDER=claude
GEMINI_API_KEY=                        # required if LLM_PROVIDER=gemini
OPENAI_API_KEY=                        # always required (powers image generation)
CLAUDE_MODEL=claude-sonnet-4-6
GEMINI_MODEL=gemini-2.0-flash
OPENAI_MODEL=gpt-5.4-mini
MAX_EVALUATIONS_PER_RUN=5
LLM_DAILY_LIMIT=20                     # daily cap for the selected LLM provider

# --- scanner thresholds ---
VELOCITY_WINDOW_HOURS=72
REPO_MAX_AGE_DAYS=365
STAR_GROWTH_MIN_PCT=50
STAR_BASE_MIN=10
MAX_CANDIDATES_PER_RUN=15
DEVPOST_MAX_PROJECTS_PER_RUN=25

# --- output paths ---
DB_PATH=reporadar.db
OUTPUT_DIR=output                      # rendered post images saved here for review

# --- scheduling ---
SCHEDULE_HOUR=6                        # local hour to fire pipeline daily
SCHEDULE_JITTER_MINUTES=15             # ±15 min jitter
TIMEZONE=UTC                           # IANA TZ name (e.g. America/New_York)
